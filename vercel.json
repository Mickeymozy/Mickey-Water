{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/login",
      "dest": "login.html"
    },
    {
      "src": "/signup",
      "dest": "signup.html"
    },
    {
      "src": "/reset-password",
      "dest": "reset-password.html"
    },
    {
      "src": "/records",
      "dest": "records.html"
    },
    {
      "src": "/dashboard",
      "dest": "dashboard.html"
    },
    {
      "src": "/admin",
      "dest": "admin-dashboard.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
