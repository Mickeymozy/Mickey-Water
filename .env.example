# ================== SERVER CONFIG ==================
NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com

# ================== DATABASE ==================
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/waterbilling?retryWrites=true&w=majority

# ================== SESSION & SECURITY ==================
SESSION_SECRET=your-super-secret-session-key-change-this

# ================== EMAIL CONFIGURATION ==================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Water Billing <noreply@waterbilling.local>

# ================== GOOGLE OAUTH ==================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-domain.com/auth/google/callback

# ================== ZENOPAY INTEGRATION ==================
ZENOPAY_API_KEY=your-zenopay-api-key
ZENOPAY_API_URL=https://api.zenoapi.com
ZENOPAY_CHECKOUT_PATH=/checkout/sessions

# ================== WEB PUSH NOTIFICATIONS ==================
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
